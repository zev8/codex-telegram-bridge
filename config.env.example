INSTANCE_NAME=default
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_ALLOWED_USER_ID=123456789
CODEX_WORKSPACE_CWD=/absolute/path/to/workspace

# Optional overrides. Most users can leave these commented out.
# INSTANCE_ROOT=~/.codex-telegram-bridge/instances/default
# DATA_DIR=./data
# TELEGRAM_FILE_DIR=./data/tg-files
# LOG_DIR=./logs
# RUN_DIR=./run

CODEX_BIN=codex
# Optional model override for this bridge. Useful when the global Codex default
# points to a model this account cannot access.
# CODEX_MODEL=gpt-5.4
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# TELEGRAM_API_BASE_URL=https://api.telegram.org

TG_POLL_TIMEOUT_SECONDS=30
TG_POLL_LIMIT=20
TG_PROGRESS_UPDATE_INTERVAL_MS=1500

# Optional fallback if local Codex is not already authenticated.
OPENAI_API_KEY=
